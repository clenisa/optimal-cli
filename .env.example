# ─────────────────────────────────────────────────────────────────────────
# optimal-cli environment variables
#
# Copy this file to .env and fill in real values. Real .env is gitignored.
# Keep this file in sync with `process.env.X` references in lib/ so future
# devs/agents don't have to guess what's required.
# ─────────────────────────────────────────────────────────────────────────

# ── Repo paths (override layout if not running on the Pi) ──
# Defaults assume `~/.openclaw/workspace/...` for optimal stack
# and `~/repos/...` for dashboards. See lib/infra/repo-paths.ts.
OPTIMAL_REPOS_ROOT=
# OPTIMAL_CLI_PATH=
# OPTIMALOS_PATH=
# DASHBOARD_RETURNPRO_PATH=
# STRAPI_CMS_PATH=
# OPTIMAL_DOCS_PATH=

# ── Kanban Board (OptimalOS Supabase instance) ──
OPTIMAL_SUPABASE_URL=https://hbfalrpswysryltysonm.supabase.co
OPTIMAL_SUPABASE_SERVICE_KEY=
# Optional: anon key for read-only browser-side flows (lib/auth/index.ts)
OPTIMAL_SUPABASE_ANON_KEY=
# Optional: pre-issued user access token (skips passphrase auth)
OPTIMAL_ACCESS_TOKEN=
OPTIMAL_OWNER_EMAIL=

# ── ReturnPro Financial Data (separate Supabase instance) ──
RETURNPRO_SUPABASE_URL=https://vvutttwunexshxkmygik.supabase.co
RETURNPRO_SUPABASE_SERVICE_KEY=

# ── Strapi CMS ──
STRAPI_URL=https://strapi.optimal.miami
STRAPI_API_TOKEN=

# ── Content Generation ──
# OpenRouter is used for content pipeline tweet generation (anthropic/claude-3-haiku)
OPENROUTER_API_KEY=
# Groq is used for social post campaigns + daily digest (NOT content pipeline)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
NEWSAPI_KEY=
NEWSAPI_QUERY=south florida commercial real estate

# ── X / Twitter (OAuth 1.0a for posting; bearer for reading) ──
X_USERNAME=
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ── Meta Graph API (Instagram + Facebook publishing) ──
META_ACCESS_TOKEN=
META_USER_ACCESS_TOKEN=
# Default IG account ID (fallback if brand-specific not set)
META_IG_ACCOUNT_ID=
# Brand-specific IG account IDs (optional, override default)
META_IG_ACCOUNT_ID_CRE_11TRUST=
META_IG_ACCOUNT_ID_LIFEINSUR=

# ── n8n (workflow automation) ──
N8N_URL=http://localhost:5678
N8N_API_KEY=
N8N_WEBHOOK_URL=

# ── Discord Bot ──
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# ── OptimalOS bridge (read activity, sync sessions) ──
OPTIMALOS_URL=http://localhost:3000

# ── OpenClaw gateway (optional) ──
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=
