                "jsonBody": "={{ JSON.stringify({ source: $json.source, source_url: $json.source_url, source_account: $json.source_account, topic: $json.topic, title: $json.title, content: $json.content, raw_json: $json.raw_json, scraped_at: $json.scraped_at }) }}"
            }
