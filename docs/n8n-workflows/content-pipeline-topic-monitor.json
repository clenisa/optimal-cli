        {
            "id": "parse-rss-items",
            "name": "Parse RSS Items",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                680,
                300
            ],
            "parameters": {
                "jsCode": "// Parse RSS XML from both GitHub feeds\nconst items = [];\n\nfor (const input of $input.all()) {\n  const xml = input.json.data || input.json.body || '';\n  const xmlStr = typeof xml === 'string' ? xml : JSON.stringify(xml);\n  \n  // Simple XML item extraction\n  const itemRegex = /<item>(.*?)<\\/item>/gs;\n  let match;\n  \n  while ((match = itemRegex.exec(xmlStr)) !== null) {\n    const itemXml = match[1];\n    const getTag = (tag) => {\n      const m = itemXml.match(new RegExp(`<${tag}>(.*?)<\\/${tag}>`, 's'));\n      return m ? m[1].replace(/<!\\[CDATA\\[|\\]\\]>/g, '').trim() : null;\n    };\n    \n    const title = getTag('title');\n    const link = getTag('link');\n    const description = getTag('description');\n    const pubDate = getTag('pubDate');\n    \n    // Determine source from URL\n    const source = link && link.includes('github.com') ? 'github' : 'rss';\n    const sourceAccount = 'anthropics';\n    \n    items.push({\n      json: {\n        source: source,\n        source_url: link,\n        source_account: sourceAccount,\n        topic: 'openclaw',\n        title: title,\n        content: description || title || 'No content',\n        raw_json: { title, link, description, pubDate },\n        scraped_at: new Date().toISOString()\n      }\n    });\n  }\n}\n\n// Deduplicate by source_url\nconst seen = new Set();\nconst unique = items.filter(item => {\n  if (seen.has(item.json.source_url)) return false;\n  seen.add(item.json.source_url);\n  return true;\n});\n\nreturn unique.length > 0 ? unique : [{ json: { _empty: true, message: 'No items parsed' } }];"
            }
        },
        {
            "id": "filter-empty",
            "name": "Filter Empty",
            "type": "n8n-nodes-base.filter",
            "typeVersion": 2,
            "position": [
                900,
                300
            ],
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict"
                    },
                    "combinator": "and",
                    "conditions": [
                        {
                            "id": "filter-empty-check",
                            "leftValue": "={{ $json._empty }}",
                            "rightValue": true,
                            "operator": {
                                "type": "boolean",
                                "operation": "notTrue"
                            }
                        }
                    ]
                }
            }
        },
        {
            "id": "check-duplicate",
            "name": "Check Duplicate",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1120,
                300
            ],
            "parameters": {
                "url": "=<OPTIMAL_SUPABASE_URL>/rest/v1/content_scraped_items?source_url=eq.{{ encodeURIComponent($json.source_url) }}&select=id&limit=1",
                "method": "GET",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "apikey",
                            "value": "<OPTIMAL_SUPABASE_SERVICE_KEY>"
                        },
                        {
                            "name": "Authorization",
                            "value": "Bearer <OPTIMAL_SUPABASE_SERVICE_KEY>"
                        }
                    ]
                },
                "options": {
                    "response": {
                        "response": {
                            "responseFormat": "json"
                        }
                    }
                }
            }
        },
        {
            "id": "filter-new-only",
            "name": "Filter New Only",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1340,
                300
            ],
            "parameters": {
                "jsCode": "// Only keep items where the duplicate check returned empty array\nconst results = [];\nfor (const item of $input.all()) {\n  const data = item.json;\n  // The HTTP response body is in .data or direct - check for empty array\n  const existing = Array.isArray(data) ? data : (data.data || data);\n  if (Array.isArray(existing) && existing.length === 0) {\n    // Not a duplicate - pass through the original scraped item\n    // We need to get it from the previous node's data stored in the item\n    results.push(item);\n  }\n}\nreturn results.length > 0 ? results : [{ json: { _skip: true } }];"
            }
        },
        {
            "id": "upsert-to-supabase",
            "name": "Insert to Supabase",
